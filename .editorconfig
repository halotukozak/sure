root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

[*.{yml,yaml,toml,json,md}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{kt,kts}]
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_function-naming = disabled
ktlint_standard_property-naming = disabled
